PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Required by svelte-clerk server hooks.
CLERK_SECRET_KEY=sk_test_replace_me

# Optional: the app already defaults to these routes.
# Both sign-in and sign-up share a single unified /login route.
PUBLIC_CLERK_SIGN_IN_URL=/login
PUBLIC_CLERK_SIGN_UP_URL=/login

# Preferred redirect variables. Clerk will honor these over the older AFTER_* names.
PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# App callback route used to finish OAuth flows after Clerk redirects back.
PUBLIC_CLERK_SSO_CALLBACK_URL=/sso-callback
PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Older aliases still supported in code for backward compatibility.
PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Set this in the Convex dashboard, not in `.env.local`.
# This is the Frontend API URL shown after activating the Convex integration in Clerk.
# Example in development:
# https://verb-noun-00.clerk.accounts.dev
CLERK_FRONTEND_API_URL=
