PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Required by svelte-clerk server hooks.
CLERK_SECRET_KEY=sk_test_replace_me

# Optional: the app already defaults to these routes.
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-up
PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Set this in the Convex dashboard, not in `.env.local`.
# This is the Frontend API URL shown after activating the Convex integration in Clerk.
# Example in development:
# https://verb-noun-00.clerk.accounts.dev
CLERK_FRONTEND_API_URL=
