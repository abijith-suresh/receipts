{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!**/*.svelte", "!.svelte-kit", "!build", "!.vercel"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"linter": {
			"enabled": false
		}
	}
}
