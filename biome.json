{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/*.svelte",
			"!.svelte-kit",
			"!build",
			"!.vercel",
			"!.agents",
			"!.claude",
			"!skills-lock.json",
			"!CLAUDE.md",
			"!src/convex/_generated/**/*.d.ts",
			"!src/convex/_generated/**/*.js"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"linter": {
			"enabled": false
		}
	}
}
